rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User document & sub-collections ────────────────────────────────────
    // Each authenticated user can only read/write their own data.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Tasks sub-collection
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Certificates sub-collection
      match /certificates/{certificateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Roadmaps sub-collection
      match /roadmaps/{roadmapId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Progress sub-collection
      match /progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Admin collection ─────────────────────────────────────────────────────
    // Any authenticated user can read their own admin doc (for login check).
    // Only the doc owner (admin) can write.
    match /admin/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == adminId;
    }

    // ── Assessments (admin posts questions for mentees) ───────────────────────
    match /assessments/{adminId}/posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == adminId;

      // Submissions sub-collection inside each assessment post
      match /submissions/{studentId} {
        allow read: if request.auth != null && (request.auth.uid == adminId || request.auth.uid == studentId);
        allow write: if request.auth != null && request.auth.uid == studentId;
      }
    }

    // ── Deny everything else by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
